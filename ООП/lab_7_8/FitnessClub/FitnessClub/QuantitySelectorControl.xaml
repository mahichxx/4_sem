<UserControl x:Class="FitnessClub.QuantitySelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FitnessClub" 
             x:Name="QuantityRoot"
             Width="120" Height="40">

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <!-- Кнопка уменьшения привязана к команде DecrementCommand -->
        <Button Content="-" Width="30" 
                Command="{x:Static local:QuantitySelectorControl.DecrementCommand}" 
                Style="{StaticResource PrimaryButton}"/>

        <!-- Текст отображает значение свойства QuantityValue -->
        <TextBlock Text="{Binding QuantityValue, ElementName=QuantityRoot}" 
                   VerticalAlignment="Center" 
                   Margin="10,0" 
                   FontWeight="Bold" 
                   FontSize="16"/>

        <!-- Кнопка увеличения привязана к команде IncrementCommand -->
        <Button Content="+" Width="30" 
                Command="{x:Static local:QuantitySelectorControl.IncrementCommand}" 
                Style="{StaticResource PrimaryButton}"/>
    </StackPanel>
</UserControl>