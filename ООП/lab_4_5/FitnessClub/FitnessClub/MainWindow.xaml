<Window x:Class="FitnessClub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}" MinWidth="900" MinHeight="600"
        Width="1200" Height="750" WindowStartupLocation="CenterScreen" Icon="icon/favicon.ico">

    <DockPanel Background="{StaticResource LightBrush}">
        <!-- Шапка -->
        <Border DockPanel.Dock="Top" Height="60" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="15,0">
                <TextBlock Text="{DynamicResource AppTitle}" Style="{StaticResource TitleText}" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox Content="Admin Mode" IsChecked="{Binding IsAdminMode}" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button Content="{DynamicResource LangSwitch}" Style="{StaticResource PrimaryButton}" Background="#43A047" Command="{Binding SwitchLanguageCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель фильтров -->
        <Border DockPanel.Dock="Top" Background="White" Padding="8" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <WrapPanel VerticalAlignment="Center">
                <TextBox Text="{Binding SearchText}" Width="150" Margin="5" Style="{StaticResource InputField}"/>
                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="140" Margin="5"/>

                <StackPanel Orientation="Horizontal" Margin="5,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource PriceFrom}" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox Text="{Binding PriceFrom}" Width="75" Style="{StaticResource InputField}"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Margin="2,0"/>
                    <TextBox Text="{Binding PriceTo}" Width="75" Style="{StaticResource InputField}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="5,0" VerticalAlignment="Center">
                    <TextBlock Text="⭐" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox Text="{Binding RatingFrom}" Width="50" Style="{StaticResource InputField}"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Margin="2,0"/>
                    <TextBox Text="{Binding RatingTo}" Width="50" Style="{StaticResource InputField}"/>
                </StackPanel>

                <Button Content="OK" Command="{Binding ApplyFilterCommand}" Width="55" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>

                <StackPanel Orientation="Horizontal" Margin="10,0">
                    <Button Content="▦" Click="BtnViewCards_Click" Padding="10,5" Margin="0,0,4,0"/>
                    <Button Content="☰" Click="BtnViewTable_Click" Padding="10,5"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="{Binding AdminVisibility}" Margin="10,0">
                    <!--  DynamicResource -->
                    <Button Content="{DynamicResource BtnAdd}" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="5,0"/>
                    <Button Content="{DynamicResource BtnDelete}" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="5,0"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150" MaxWidth="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource DarkBrush}">
                <StackPanel Margin="0,20">
                    <TextBlock Text="{DynamicResource MenuServices}" Foreground="White" Margin="20,10" Cursor="Hand" MouseLeftButtonUp="NavServices_Click"/>
                    <TextBlock Text="{DynamicResource MenuManage}" Foreground="White" Margin="20,10" Cursor="Hand" MouseLeftButtonUp="NavManage_Click"/>
                </StackPanel>
            </Border>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#CCC"/>

            <Grid Grid.Column="2" Margin="10">
                <ScrollViewer x:Name="CardsView">
                    <WrapPanel x:Name="ServicesPanel" HorizontalAlignment="Center"/>
                </ScrollViewer>
                <DataGrid x:Name="TableView" Visibility="Collapsed" ItemsSource="{Binding ServicesView}" SelectedItem="{Binding SelectedService}" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource ColName}" Binding="{Binding ShortName}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource ColPrice}" Binding="{Binding Price}" Width="100"/>
                        <DataGridTextColumn Header="{DynamicResource ColRating}" Binding="{Binding Rating}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>