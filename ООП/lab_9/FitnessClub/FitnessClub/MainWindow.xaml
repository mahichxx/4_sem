<Window x:Class="FitnessClub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FitnessClub" 
        Title="{DynamicResource AppTitle}" MinWidth="900" MinHeight="600"
        Width="1200" Height="750" WindowStartupLocation="CenterScreen">

    <!-- Привязка клавиш клавиатуры -->
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{x:Static local:AppCommands.ApplyFilters}"/>
        <KeyBinding Key="R" Modifiers="Control" Command="{x:Static local:AppCommands.ClearFilters}"/>
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:AppCommands.ClearFilters}" Executed="ClearFilters_Executed" />
        <CommandBinding Command="{x:Static local:AppCommands.ApplyFilters}" Executed="ApplyFilters_Executed" />
    </Window.CommandBindings>

    <DockPanel Background="{DynamicResource WindowBrush}" 
               local:QuantitySelectorControl.QuantityChanged="OnQuantityChangedUserFriendly">

        <!-- ШАПКА -->
        <Border DockPanel.Dock="Top" Height="60" Background="{DynamicResource PrimaryBrush}">
            <Grid Margin="15,0">
                <TextBlock Text="{DynamicResource AppTitle}" Style="{StaticResource TitleText}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="↩" Command="{Binding UndoCommand}" Style="{StaticResource PrimaryButton}" Width="35" Height="35" Margin="5,0"/>
                    <Button Content="↪" Command="{Binding RedoCommand}" Style="{StaticResource PrimaryButton}" Width="35" Height="35" Margin="5,0"/>
                    <CheckBox Content="Admin Mode" IsChecked="{Binding IsAdminMode}" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                    <Button Style="{StaticResource RoundButtonStyle}" Content="👤" Click="OpenProfile_Click" Margin="10,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ПАНЕЛЬ ФИЛЬТРОВ -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource CardBrush}" Padding="8" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <WrapPanel VerticalAlignment="Center">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="5" Style="{StaticResource InputField}"/>
                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="140" Margin="5"/>

                <StackPanel Orientation="Horizontal" Margin="10,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource PriceFrom}" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox Text="{Binding PriceFrom, UpdateSourceTrigger=PropertyChanged}" Width="65" Style="{StaticResource InputField}"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Margin="2,0"/>
                    <TextBox Text="{Binding PriceTo, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
         Width="65" Style="{StaticResource InputField}"/>
                </StackPanel>

                <!-- Кнопка ОК (Теперь работает по Enter) -->
                <Button Content="OK" Command="{x:Static local:AppCommands.ApplyFilters}" IsDefault="True" Width="50" Style="{StaticResource PrimaryButton}" Margin="5,0"/>

                <!-- Кнопка СБРОС -->
                <Button Content="Сброс (Ctrl+R)" Command="{x:Static local:AppCommands.ClearFilters}" Margin="5,0" Style="{StaticResource DangerButton}"/>

                <!-- Счетчик -->
                <StackPanel Orientation="Horizontal" Margin="10,0">
                    <TextBlock Text="Кол-во занятий:" VerticalAlignment="Center" Margin="5,0"/>
                    <local:QuantitySelectorControl 
    QuantityValue="{Binding TargetQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
    x:Name="MyQuantitySelector"/>
                </StackPanel>

                <!-- Кнопки Админа (появляются только в Admin Mode) -->
                <StackPanel Orientation="Horizontal" Visibility="{Binding AdminVisibility}" Margin="10,0">
                    <Button Content="➕ Добавить" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="5,0" Width="100"/>
                    <Button Content="🗑️ Удалить" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="5,0" Width="100"/>
                </StackPanel>

            </WrapPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource DarkBrush}">
                <StackPanel Margin="0,20">
                    <TextBlock Text="{DynamicResource MenuServices}" Foreground="White" Margin="20,10" Cursor="Hand" MouseLeftButtonUp="NavServices_Click"/>
                    <TextBlock Text="{DynamicResource MenuManage}" Foreground="White" Margin="20,10" Cursor="Hand" MouseLeftButtonUp="NavManage_Click"/>
                </StackPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#CCC"/>

            <Grid Grid.Column="2" Margin="10">
                <ScrollViewer x:Name="CardsView">
                    <WrapPanel x:Name="ServicesPanel" HorizontalAlignment="Center" local:ServiceCardControl.CardSelected="OnServiceCardSelected"/>
                </ScrollViewer>
                <DataGrid x:Name="TableView" Visibility="Collapsed" ItemsSource="{Binding ServicesView}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource ColName}" Binding="{Binding ShortName}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource ColPrice}" Binding="{Binding Price}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>