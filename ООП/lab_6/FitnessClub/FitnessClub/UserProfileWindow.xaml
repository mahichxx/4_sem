<Window x:Class="FitnessClub.UserProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ProfileTitle}" MinHeight="400" MinWidth="400" Width="450" Height="480"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource WindowBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource ProfileTitle}" Style="{StaticResource TitleText}" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="{DynamicResource ProfileName}" FontSize="13" Margin="0,0,5,5"/>
            <TextBox Style="{StaticResource InputField}" Text="Мария" Height="30"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="{DynamicResource ProfileThemeHeader}" FontWeight="Bold" Margin="0,0,0,10"/>
            <UniformGrid Columns="3">
                <Button Content="{DynamicResource ThemeLight}" Click="SetLightTheme_Click" Height="32" Margin="2" Style="{StaticResource PrimaryButton}"/>
                <Button Content="{DynamicResource ThemeDark}" Click="SetDarkTheme_Click" Height="32" Margin="2" Style="{StaticResource PrimaryButton}"/>
                <Button Content="{DynamicResource ThemePink}" Click="SetPinkTheme_Click" Height="32" Margin="2" Style="{StaticResource PrimaryButton}"/>
            </UniformGrid>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource ProfileLangHeader}" FontWeight="Bold" Margin="0,0,0,5"/>
            <Button Content="{DynamicResource LangSwitch}" Command="{Binding SwitchLanguageCommand}" Style="{StaticResource PrimaryButton}" Height="32" Width="90" HorizontalAlignment="Left"/>
        </StackPanel>

        <Button Grid.Row="5" Content="{DynamicResource ProfileClose}" Click="Close_Click" Height="38" Width="150" HorizontalAlignment="Center" Style="{StaticResource DangerButton}"/>
    </Grid>
</Window>