<UserControl x:Class="FitnessClub.ServiceCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FitnessClub"
             x:Name="CardRoot"
             Width="230" Margin="10">

    <UserControl.Resources>
        <!-- Конвертер для превращения true/false в видимость -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Border x:Name="MainBorder" 
            Style="{StaticResource ServiceCard}" 
            Background="White" 
            MouseLeftButtonDown="MainBorder_MouseLeftButtonDown"
            RenderTransformOrigin="0.5,0.5">

        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Картинка -->
                <RowDefinition Height="*"/>
                <!-- Инфо -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки управления -->
            </Grid.RowDefinitions>

            <!-- 1. Изображение -->
            <Image Grid.Row="0" 
                   Source="{Binding ServiceImage, ElementName=CardRoot, TargetNullValue='https://via.placeholder.com/230x130?text=No+Image'}" 
                   Height="130" 
                   Stretch="UniformToFill">
                <Image.Clip>
                    <RectangleGeometry Rect="0,0,230,130" RadiusX="10" RadiusY="10"/>
                </Image.Clip>
            </Image>

            <!-- 2. Информация -->
            <StackPanel Grid.Row="1" Margin="5,10">
                <TextBlock Text="{Binding ServiceTitle, ElementName=CardRoot}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                <TextBlock Text="{Binding CategoryName, ElementName=CardRoot}" Opacity="0.5" HorizontalAlignment="Center" FontSize="12" Margin="0,2"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                    <TextBlock Text="⭐ " Foreground="Gold"/>
                    <TextBlock Text="{Binding RatingValue, ElementName=CardRoot}" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="{Binding PriceValue, ElementName=CardRoot, StringFormat='{}{0} руб.'}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,5"/>

                <!-- Кнопка "Подробнее" видна всем -->
                <Button Content="Подробнее" Command="{x:Static local:ServiceCardControl.OpenDetailsCommand}" Height="30" Margin="5,2" Background="{DynamicResource PrimaryBrush}" Foreground="White"/>
            </StackPanel>

            <!-- 3. Кнопки АДМИНА (Показываются только если IsAdmin=True) -->
            <UniformGrid Grid.Row="2" Columns="2" Margin="5"
                         Visibility="{Binding IsAdmin, ElementName=CardRoot, Converter={StaticResource BoolToVis}}">
                <Button Content="✏️ Изменить" 
                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                        CommandParameter="{Binding DataContext, ElementName=CardRoot}" Height="32" Margin="2" FontSize="11" Background="White"/>
                <Button Content="🗑️ Удалить" 
                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                        CommandParameter="{Binding DataContext, ElementName=CardRoot}" Height="32" Margin="2" FontSize="11" Background="{DynamicResource DangerBrush}" Foreground="White"/>
            </UniformGrid>
        </Grid>

        <!-- Анимация -->
        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                        <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                        <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
    </Border>
</UserControl>