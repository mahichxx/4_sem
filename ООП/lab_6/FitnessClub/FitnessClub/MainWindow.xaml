<Window x:Class="FitnessClub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}" MinWidth="900" MinHeight="600"
        Width="1200" Height="750" WindowStartupLocation="CenterScreen">

    <DockPanel Background="{DynamicResource WindowBrush}">
        <!-- ШАПКА -->
        <Border DockPanel.Dock="Top" Height="60" Background="{DynamicResource PrimaryBrush}">
            <Grid Margin="15,0">
                <TextBlock Text="{DynamicResource AppTitle}" Style="{StaticResource TitleText}" VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Задание 8: Undo / Redo -->
                    <Button Content="↩" Command="{Binding UndoCommand}" Style="{StaticResource PrimaryButton}" 
                            Width="35" Height="35" FontSize="18" Margin="5,0" ToolTip="Отмена"/>
                    <Button Content="↪" Command="{Binding RedoCommand}" Style="{StaticResource PrimaryButton}" 
                            Width="35" Height="35" FontSize="18" Margin="5,0" ToolTip="Повтор"/>

                    <CheckBox Content="Admin Mode" IsChecked="{Binding IsAdminMode}" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>

                    <!-- Задание 6: Круглая кнопка профиля -->
                    <Button Style="{StaticResource RoundButtonStyle}" Content="👤" Click="OpenProfile_Click" Margin="10,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ПАНЕЛЬ ФИЛЬТРОВ -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource CardBrush}" Padding="8" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <WrapPanel VerticalAlignment="Center">
                <!-- Поиск с триггером (Задание 2) -->
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Width="150" Margin="5" Style="{StaticResource InputField}"/>

                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="140" Margin="5"/>

                <!-- Фильтр по цене -->
                <StackPanel Orientation="Horizontal" Margin="10,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource PriceFrom}" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox Text="{Binding PriceFrom}" Width="65" Style="{StaticResource InputField}"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Margin="2,0"/>
                    <TextBox Text="{Binding PriceTo}" Width="65" Style="{StaticResource InputField}"/>
                </StackPanel>

                <Button Content="OK" Command="{Binding ApplyFilterCommand}" Width="50" Style="{StaticResource PrimaryButton}" Margin="5,0"/>

                <!-- Переключатели вида (Карточки/Таблица) -->
                <StackPanel Orientation="Horizontal" Margin="10,0">
                    <Button Content="▦" Click="BtnViewCards_Click" Width="35" Height="30" Margin="0,0,5,0"/>
                    <Button Content="☰" Click="BtnViewTable_Click" Width="35" Height="30"/>
                </StackPanel>

                <!-- Кнопки Админа -->
                <StackPanel Orientation="Horizontal" Visibility="{Binding AdminVisibility}" Margin="10,0">
                    <Button Content="{DynamicResource BtnAdd}" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="5,0" Width="85"/>
                    <Button Content="{DynamicResource BtnDelete}" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Margin="5,0" Width="85"/>
                </StackPanel>

            </WrapPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150" MaxWidth="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковое меню -->
            <Border Grid.Column="0" Background="{DynamicResource DarkBrush}">
                <StackPanel Margin="0,20">
                    <TextBlock Text="{DynamicResource MenuServices}" Foreground="White" Margin="20,10" Cursor="Hand" MouseLeftButtonUp="NavServices_Click"/>
                    <TextBlock Text="{DynamicResource MenuManage}" Foreground="White" Margin="20,10" Cursor="Hand" MouseLeftButtonUp="NavManage_Click"/>
                </StackPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#CCC"/>

            <!-- КОНТЕНТ (Важные имена: CardsView, TableView, ServicesPanel) -->
            <Grid Grid.Column="2" Margin="10">
                <!-- Вид карточками -->
                <ScrollViewer x:Name="CardsView" Visibility="Visible">
                    <WrapPanel x:Name="ServicesPanel" HorizontalAlignment="Center"/>
                </ScrollViewer>

                <!-- Вид таблицей -->
                <DataGrid x:Name="TableView" Visibility="Collapsed" 
                          ItemsSource="{Binding ServicesView}" 
                          SelectedItem="{Binding SelectedService}" 
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource ColName}" Binding="{Binding ShortName}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource ColPrice}" Binding="{Binding Price}" Width="100"/>
                        <DataGridTextColumn Header="{DynamicResource ColRating}" Binding="{Binding Rating}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>