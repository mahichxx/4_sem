<UserControl x:Class="FitnessClub.ServiceCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="230" Margin="10">

    <Border x:Name="MainBorder" Style="{StaticResource ServiceCard}" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Картинка -->
                <RowDefinition Height="*"/>
                <!-- Инфо (Центр) -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки (Низ) -->
            </Grid.RowDefinitions>

            <!-- 1. Изображение -->
            <Image Grid.Row="0" Source="{Binding Images[0]}" Height="130" Stretch="UniformToFill">
                <Image.Clip>
                    <RectangleGeometry Rect="0,0,230,130" RadiusX="10" RadiusY="10"/>
                </Image.Clip>
            </Image>

            <!-- 2. Информация (теперь больше данных) -->
            <StackPanel Grid.Row="1" Margin="5,10">
                <TextBlock Text="{Binding ShortName}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                <TextBlock Text="{Binding Category}" Opacity="0.5" HorizontalAlignment="Center" FontSize="12" Margin="0,2"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                    <TextBlock Text="⭐ " Foreground="Gold"/>
                    <TextBlock Text="{Binding Rating}" FontWeight="Bold"/>
                    <!-- Показываем скидку только если она > 0 -->
                    <TextBlock Text="{Binding DiscountPercent, StringFormat='  -{0}%'}" Foreground="Red" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DiscountPercent}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <TextBlock Text="{Binding Price, StringFormat='{}{0} руб.'}" Foreground="{DynamicResource PrimaryBrush}" 
                           FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,5"/>
            </StackPanel>

            <!-- 3. Кнопки внизу (Админ) -->
            <UniformGrid Grid.Row="2" Columns="2" Margin="0,5,0,0"
                         Visibility="{Binding DataContext.AdminVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                <Button Content="✏️ Изменить" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                        CommandParameter="{Binding}" Height="32" Margin="2" FontSize="11" Background="White"/>
                <Button Content="🗑️ Удалить" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                        CommandParameter="{Binding}" Height="32" Margin="2" FontSize="11" Background="{DynamicResource DangerBrush}" Foreground="White"/>
            </UniformGrid>
        </Grid>

        <!-- ПРАВИЛЬНАЯ АНИМАЦИЯ (Пропорциональный Зум) -->
        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                        <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                        <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
    </Border>
</UserControl>