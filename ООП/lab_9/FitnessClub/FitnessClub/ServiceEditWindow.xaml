<Window x:Class="FitnessClub.ServiceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Фитнес Клуб - Редактирование" 
        MinHeight="600" MinWidth="450" 
        Width="500" Height="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/> <!-- Поля -->
                <RowDefinition Height="Auto"/> <!-- Кнопки -->
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Краткое название:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtShortName" Style="{StaticResource InputField}" Margin="0,0,0,15"/>

                <TextBlock Text="Полное название:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtFullName" Style="{StaticResource InputField}" Margin="0,0,0,15"/>

                <TextBlock Text="Описание:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtDescription" Style="{StaticResource InputField}" 
                         Height="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,15"/>

                <TextBlock Text="Категория:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbCategory" Height="30" Margin="0,0,0,15" IsEditable="True"/>
                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Цена (руб.):" FontWeight="Bold"/>
                        <TextBox x:Name="TxtPrice" Style="{StaticResource InputField}"/>
                    </StackPanel>
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="Скидка (%):" FontWeight="Bold"/>
                        <TextBox x:Name="TxtDiscount" Style="{StaticResource InputField}"/>
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="2" Margin="0,0,0,15">
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Рейтинг (0-5):" FontWeight="Bold"/>
                        <TextBox x:Name="TxtRating" Style="{StaticResource InputField}"/>
                    </StackPanel>
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="Количество:" FontWeight="Bold"/>
                        <TextBox x:Name="TxtQuantity" Style="{StaticResource InputField}"/>
                    </StackPanel>
                </UniformGrid>

                <TextBlock Text="Изображения:" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <!-- Скрытое поле для пути, которое требует ваш код -->
                        <TextBlock x:Name="TxtImagePath" Visibility="Collapsed"/>
                        <TextBlock Text="📁 Перетащите изображение сюда" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.5"/>
                        <Button Content="Выбрать файл.." Click="SelectImage_Click" Style="{StaticResource PrimaryButton}" Width="150"/>
                    </StackPanel>
                </Border>

                <CheckBox x:Name="ChkInStock" Content="В наличии" FontWeight="Bold" Margin="0,0,0,20"/>
            </StackPanel>

            <!-- Кнопки управления -->
            <UniformGrid Grid.Row="1" Columns="2">
                <Button Content="💾 Сохранить" IsDefault="True" Click="Save_Click" Style="{StaticResource PrimaryButton}" Height="40" Margin="5"/>
                <Button Content="Отмена" IsCancel="True" Click="Cancel_Click" Style="{StaticResource DangerButton}" Height="40" Margin="5"/>
            </UniformGrid>
        </Grid>
    </ScrollViewer>
</Window>