<Window x:Class="FitnessClub.ServiceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}"
        Width="450" Height="650" 
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource LightBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock Text="{DynamicResource EditShortName}" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtShortName" Style="{StaticResource InputField}" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource EditFullName}" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtFullName" Style="{StaticResource InputField}" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource EditDescription}" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtDescription" Style="{StaticResource InputField}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource EditCategory}" FontWeight="Bold" Margin="0,0,0,4"/>
            <ComboBox x:Name="CmbCategory" IsEditable="True" Margin="0,0,0,12">
                <ComboBoxItem>Групповые</ComboBoxItem>
                <ComboBoxItem>Индивидуальные</ComboBoxItem>
                <ComboBoxItem>Водные</ComboBoxItem>
                <ComboBoxItem>Силовые</ComboBoxItem>
            </ComboBox>

            <UniformGrid Columns="2">
                <StackPanel Margin="0,0,5,0">
                    <TextBlock Text="{DynamicResource EditPrice}" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtPrice" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                </StackPanel>
                <StackPanel Margin="5,0,0,0">
                    <TextBlock Text="{DynamicResource EditDiscount}" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtDiscount" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                </StackPanel>
            </UniformGrid>

            <UniformGrid Columns="2">
                <StackPanel Margin="0,0,5,0">
                    <TextBlock Text="{DynamicResource EditRating}" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtRating" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                </StackPanel>
                <StackPanel Margin="5,0,0,0">
                    <TextBlock Text="{DynamicResource EditQuantity}" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtQuantity" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                </StackPanel>
            </UniformGrid>

            <TextBlock Text="{DynamicResource EditImages}" FontWeight="Bold" Margin="0,0,0,4"/>
            <Border x:Name="DropZone" Height="60" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" Background="#F1F8E9" CornerRadius="6" Margin="0,0,0,4" AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource EditDropHint}" Foreground="Gray" FontSize="12"/>
                    <TextBlock x:Name="TxtImagePath" Foreground="{StaticResource PrimaryBrush}" FontSize="11"/>
                </StackPanel>
            </Border>
            <Button x:Name="BtnBrowse" Content="Выбрать файл..." Margin="0,0,0,12" Click="BtnBrowse_Click"/>

            <CheckBox x:Name="ChkInStock" Content="{DynamicResource EditInStock}" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource BtnSave}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="BtnSave_Click"/>
                <Button Content="{DynamicResource BtnCancel}" Padding="16,8" Click="BtnCancel_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>